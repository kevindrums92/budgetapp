<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SmartSpend"
            android:textColor="@color/widget_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_privacy"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:layout_marginEnd="6dp"
            android:textSize="14sp"
            android:textColor="@color/widget_text_secondary" />

        <TextView
            android:id="@+id/transaction_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Today -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/label_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="$ 0"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Divider -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="8dp"
            android:background="@color/widget_text_tertiary" />

        <!-- Month -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/label_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mes"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="$ 0"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Divider -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="8dp"
            android:background="@color/widget_text_tertiary" />

        <!-- Remaining -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/label_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restante"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="$ 0"
                android:textColor="@color/widget_teal"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="14dp" />

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- Recent header -->
    <TextView
        android:id="@+id/label_recent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recientes"
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="4dp" />

    <!-- Transaction rows container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Empty state -->
        <TextView
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Sin movimientos recientes"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/transaction_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/dot_1"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_category_dot" />

            <TextView
                android:id="@+id/name_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/transaction_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/dot_2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_category_dot" />

            <TextView
                android:id="@+id/name_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/transaction_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/dot_3"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_category_dot" />

            <TextView
                android:id="@+id/name_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:id="@+id/transaction_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/dot_4"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_category_dot" />

            <TextView
                android:id="@+id/name_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Row 5 -->
        <LinearLayout
            android:id="@+id/transaction_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/dot_5"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_category_dot" />

            <TextView
                android:id="@+id/name_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amount_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_voice"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_button_teal"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_voice_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#127908; Voz"
                android:textColor="@color/widget_teal"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/widget_button_dark"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_add_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Agregar"
                android:textColor="@color/widget_button_text_light"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
